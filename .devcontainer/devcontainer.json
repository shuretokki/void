{
  "name": "Void Dev Environment",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/nix:1": {
      "version": "latest",
      "multiUser": true
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "jnoortheen.nix-ide",
        "mkhl.direnv",
        "arrterian.nix-env-selector",
        "christian-kohler.path-intellisense"
      ],
      "settings": {
        "nix.enableLanguageServer": true,
        "nix.serverPath": "nil"
      }
    }
  },
  "remoteUser": "vscode",
  "postCreateCommand": "nix profile install nixpkgs#direnv nixpkgs#nil && direnv allow && nix develop --command true"
}